# Python / packaging
.venv/
__pycache__/
*.pyc
*.egg-info/
dist/
build/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Tooling
.python-version
.DS_Store

# Never commit dotenv files. The project does not use .env at all — all
# config lives in <data_dir>/config.yaml or real environment variables.
# Ignored defensively so nobody accidentally checks one in.
.env
.env.*

# Repo-local runtime data dir — contains real attachment bytes, extracted
# text, and PII spans. Auto-created by load_settings() when running from a
# source checkout (see inboxaudit/config.py::default_data_dir). The
# pre-rename name is kept here defensively until users migrate.
.inboxaudit-data/
.inbox-scanner-data/

# Browser-driven smoke-test artifacts. Screenshots can contain rendered
# PII from the dev corpus (the UI literally paints highlighted spans of
# real user data) — never commit them.
.playwright-mcp/
*.png
*.jpg
*.jpeg
!docs/**/*.png
!docs/**/*.jpg
!docs/**/*.jpeg

# Exported Claude Code conversation transcripts. Kept on disk under
# docs/archives/ for personal reference; never committed (they contain
# real PII from the dev corpus that surfaced during development).
docs/archives/cc-conversations-*.txt
